# Azure DevOps Integration Settings
# Copy this file to .env and fill in your values

# ============================================
# AZURE DEVOPS CONFIGURATION
# ============================================

# Your Azure DevOps organization name (from https://dev.azure.com/{org})
AZURE_DEVOPS_ORG=your-organization

# The project name within your organization
AZURE_DEVOPS_PROJECT=your-project

# Personal Access Token (PAT) with Work Items: Read & Write scope
# Create at: https://dev.azure.com/{org}/_usersSettings/tokens
# Required scopes: Work Items (Read & Write)
AZURE_DEVOPS_PAT=your-personal-access-token

# ============================================
# CUSTOM FIELD NAMES
# ============================================
# These are the field reference names for your "Event Summary Log" work item type
# Find your field names at: Organization Settings > Process > Your Process > Event Summary Log

# Field containing feedback HTML with embedded images
# Default: Custom.Feedback
AZURE_DEVOPS_FEEDBACK_FIELD=Custom.Feedback

# Field containing the event date
# Default: Custom.EventDate  
AZURE_DEVOPS_EVENTDATE_FIELD=Custom.EventDate

# ============================================
# STORAGE SETTINGS
# ============================================

# Storage mode: 'blob' for Azure Blob Storage, 'local' for local file system
STORAGE_MODE=local

# Azure Blob Storage connection string (required if STORAGE_MODE=blob)
# AZURE_STORAGE_CONNECTION_STRING=your-connection-string
